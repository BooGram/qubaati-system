{
  "info": {
    "_postman_id": "91c7417c-9efa-4d8e-83f9-52b5e9cebb73",
    "name": "Qubaati - PDF Report Full Flow",
    "description": "Full Postman flow for an empty database: create parent, create child, check learning profile JSON, then download the Arabic student portfolio PDF.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Set Random Test Data",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now();",
              "pm.collectionVariables.set('suffix', suffix);",
              "pm.collectionVariables.set('parentUsername', 'parent_' + suffix);",
              "pm.collectionVariables.set('parentEmail', 'parent_' + suffix + '@qubaati.test');",
              "pm.collectionVariables.set('studentUsername', 'student_' + suffix);",
              "pm.collectionVariables.set('studentEmail', 'student_' + suffix + '@qubaati.test');",
              "pm.test('Random variables created', function () {",
              "  pm.expect(pm.collectionVariables.get('suffix')).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/subscriptions/plans",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "subscriptions",
            "plans"
          ]
        },
        "description": "This request also confirms the backend is running, then creates unique usernames/emails for the flow."
      },
      "response": []
    },
    {
      "name": "1. Create Parent",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Parent created', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('parentId', body.id);",
              "pm.collectionVariables.set('parentUserId', body.userId);",
              "",
              "pm.test('parentId saved', function () {",
              "  pm.expect(pm.collectionVariables.get('parentId')).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{parentUsername}}\",\n  \"email\": \"{{parentEmail}}\",\n  \"password\": \"password123\",\n  \"fullName\": \"أحمد صالح\",\n  \"phoneNumber\": \"0551234566\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/parents",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "parents"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Create Child Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Child student created', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('studentId', body.id);",
              "pm.collectionVariables.set('studentUserId', body.userId);",
              "",
              "pm.test('studentId saved', function () {",
              "  pm.expect(pm.collectionVariables.get('studentId')).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{studentUsername}}\",\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"password123\",\n  \"fullName\": \"فهد صالح\",\n  \"age\": 9,\n  \"grade\": \"ثالث ابتدائي\",\n  \"classroomId\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/parents/{{parentId}}/children",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "parents",
            "{{parentId}}",
            "children"
          ]
        },
        "description": "Creates a child under the parent created in request #1. The response saves studentId automatically."
      },
      "response": []
    },
    {
      "name": "3. Check Parent Children",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/parents/{{parentId}}/children",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "parents",
            "{{parentId}}",
            "children"
          ]
        },
        "description": "Optional check that the child belongs to the parent."
      },
      "response": []
    },
    {
      "name": "4. Check Child Learning Profile JSON",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Learning profile loaded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Learning profile has student info', function () {",
              "  pm.expect(body.studentId).to.eql(Number(pm.collectionVariables.get('studentId')));",
              "  pm.expect(body.fullName).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/parents/{{parentId}}/children/{{studentId}}/learning-profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "parents",
            "{{parentId}}",
            "children",
            "{{studentId}}",
            "learning-profile"
          ]
        },
        "description": "The PDF uses this same learning profile data. In an empty DB, skills/insights/recommendations may be empty, and that is OK."
      },
      "response": []
    },
    {
      "name": "5. Download Student Portfolio PDF",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('PDF generated', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/pdf"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/parents/{{parentId}}/children/{{studentId}}/learning-profile/pdf",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "parents",
            "{{parentId}}",
            "children",
            "{{studentId}}",
            "learning-profile",
            "pdf"
          ]
        },
        "description": "Click Send, then in Postman choose Save Response -> Save to a file to open the PDF."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "suffix",
      "value": "",
      "type": "string"
    },
    {
      "key": "parentUsername",
      "value": "",
      "type": "string"
    },
    {
      "key": "parentEmail",
      "value": "",
      "type": "string"
    },
    {
      "key": "parentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "parentUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "studentUsername",
      "value": "",
      "type": "string"
    },
    {
      "key": "studentEmail",
      "value": "",
      "type": "string"
    },
    {
      "key": "studentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "studentUserId",
      "value": "",
      "type": "string"
    }
  ]
}
