  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get(\"runId\")) {",
          "  pm.environment.set(\"runId\", Date.now().toString());",
          "}",
          "pm.environment.set(\"parentUsername\", \"wali_\" + pm.environment.get(\"runId\"));",
          "pm.environment.set(\"parentEmail\", \"wali_\" + pm.environment.get(\"runId\") + \"@qubaati.test\");",
          "pm.environment.set(\"studentUsername\", \"fahad_\" + pm.environment.get(\"runId\"));",
          "pm.environment.set(\"studentEmail\", \"fahad_\" + pm.environment.get(\"runId\") + \"@qubaati.test\");",
          "pm.environment.set(\"skillAnalysisName\", \"التفكير التحليلي \" + pm.environment.get(\"runId\"));",
          "pm.environment.set(\"skillDecisionName\", \"اتخاذ القرار \" + pm.environment.get(\"runId\"));",
          "pm.environment.set(\"skillCreativeName\", \"التفكير الإبداعي \" + pm.environment.get(\"runId\"));",
          "pm.environment.set(\"worldTitle\", \"عالم الهندسة \" + pm.environment.get(\"runId\"));",
          "pm.environment.set(\"missionTitle\", \"تحدي الجسر الذكي \" + pm.environment.get(\"runId\"));"
        ]
      }
    }
  ],
