              "pm.test(\"response is json\", function () { pm.response.to.have.header(\"Content-Type\"); });",
              "const skills = pm.response.json();",
              "function byName(name) { return skills.find(s => s.name === pm.environment.get(name)); }",
              "const analysis = byName(\"skillAnalysisName\");",
              "const decision = byName(\"skillDecisionName\");",
              "const creative = byName(\"skillCreativeName\");",
              "pm.test(\"all skills found\", function () { pm.expect(analysis).to.exist; pm.expect(decision).to.exist; pm.expect(creative).to.exist; });",
              "if (analysis) pm.environment.set(\"skillAnalysisId\", analysis.id);",
              "if (decision) pm.environment.set(\"skillDecisionId\", decision.id);",
              "if (creative) pm.environment.set(\"skillCreativeId\", creative.id);"
            ]
