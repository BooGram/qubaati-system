meta {
  name: ah - Get CareerWorlds (save careerWorldId)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/career-worlds/get-all
  body: none
  auth: basic
}

auth:basic {
  username: {{adminUsername}}
  password: {{adminPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  const cw = Array.isArray(json) ? json.filter(x => x.title === 'Engineering World').pop() : null;
  if (cw) bru.setVar('careerWorldId', cw.id);
}
