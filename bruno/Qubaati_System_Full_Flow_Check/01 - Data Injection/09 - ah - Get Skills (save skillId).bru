meta {
  name: ah - Get Skills (save skillId)
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/skills/get-all
  body: none
  auth: basic
}

auth:basic {
  username: {{adminUsername}}
  password: {{adminPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  const s = Array.isArray(json) ? json.filter(x => x.name === 'Problem Solving').pop() : null;
  if (s) bru.setVar('skillId', s.id);
}
