meta {
  name: ab - Get Child Mission History
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/parents/me/children/mission-history
  body: json
  auth: basic
}

auth:basic {
  username: {{parentUsername}}
  password: {{parentPassword}}
}

headers {
  Content-Type: application/json
}

body:json {
  {"studentId": {{studentId}}}
}

tests {
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('returns an array', () => expect(res.getBody()).to.be.an('array'));
}
