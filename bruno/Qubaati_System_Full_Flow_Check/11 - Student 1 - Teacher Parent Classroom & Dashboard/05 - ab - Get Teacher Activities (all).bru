meta {
  name: ab - Get Teacher Activities (all)
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/teachers/me/activities
  body: none
  auth: basic
}

auth:basic {
  username: {{teacherUsername}}
  password: {{teacherPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('teacher owns at least the seeded activity', () => expect(json).to.be.an('array').that.is.not.empty);
}
