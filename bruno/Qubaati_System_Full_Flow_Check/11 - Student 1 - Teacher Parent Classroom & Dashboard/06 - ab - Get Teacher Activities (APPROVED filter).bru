meta {
  name: ab - Get Teacher Activities (APPROVED filter)
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/teachers/me/activities?status=APPROVED
  body: none
  auth: basic
}

auth:basic {
  username: {{teacherUsername}}
  password: {{teacherPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('all returned are APPROVED', () => json.forEach(a => expect(a.status).to.eql('APPROVED')));
}
