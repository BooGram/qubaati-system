meta {
  name: am - Verify SUBMISSION_REOPENED notification
  type: http
  seq: 26
}

get {
  url: {{baseUrl}}/users/me/notifications
  body: none
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('student got a SUBMISSION_REOPENED notification', () => expect(json.some(n => n.type === 'SUBMISSION_REOPENED')).to.eql(true));
}
