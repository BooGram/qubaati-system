meta {
  name: am - Capture Points Before Submit
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/students/me
  body: none
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  bru.setVar('s2PointsPreSubmit', json.totalPoints || 0);
}
