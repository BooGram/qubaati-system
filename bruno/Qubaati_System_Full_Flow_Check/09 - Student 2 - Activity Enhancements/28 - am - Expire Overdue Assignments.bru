meta {
  name: am - Expire Overdue Assignments
  type: http
  seq: 28
}

patch {
  url: {{baseUrl}}/activity-assignments/expire-overdue
  body: none
  auth: basic
}

auth:basic {
  username: {{teacherUsername}}
  password: {{teacherPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('at least one assignment expired', () => expect(json.expiredCount).to.be.at.least(1));
}
