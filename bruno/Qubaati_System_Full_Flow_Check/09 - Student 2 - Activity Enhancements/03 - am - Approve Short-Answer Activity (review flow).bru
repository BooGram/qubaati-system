meta {
  name: am - Approve Short-Answer Activity (review flow)
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/activities/approve
  body: json
  auth: basic
}

auth:basic {
  username: {{teacherUsername}}
  password: {{teacherPassword}}
}

headers {
  Content-Type: application/json
}

body:json {
  {"reviewComment": "Approved for assignment", "activityId": {{s2ActivityId}}}
}

tests {
  test('status 200', () => expect(res.getStatus()).to.equal(200));
}
