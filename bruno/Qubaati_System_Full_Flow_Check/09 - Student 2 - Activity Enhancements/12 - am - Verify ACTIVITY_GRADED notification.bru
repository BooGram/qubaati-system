meta {
  name: am - Verify ACTIVITY_GRADED notification
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/users/me/notifications
  body: none
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('student got an ACTIVITY_GRADED notification', () => expect(json.some(n => n.type === 'ACTIVITY_GRADED')).to.eql(true));
}
