meta {
  name: ah - Start Mission 2
  type: http
  seq: 20
}

post {
  url: {{baseUrl}}/missions/sessions/start
  body: json
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

headers {
  Content-Type: application/json
}

body:json {
  {"missionId": {{mission2Id}}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  bru.setVar('sessionId', json.sessionId);
  bru.setVar('choiceId', json.currentStep.choices[0].id);
}
