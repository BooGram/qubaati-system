meta {
  name: ah - Get Student Recommendations
  type: http
  seq: 41
}

get {
  url: {{baseUrl}}/students/me/recommendations
  body: none
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('recommendations were generated', () => expect(json).to.be.an('array').that.is.not.empty);
}
