meta {
  name: am - Generate Activity (EN)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/ai/activities/generate?language=en
  body: json
  auth: basic
}

auth:basic {
  username: {{teacherUsername}}
  password: {{teacherPassword}}
}

headers {
  Content-Type: application/json
}

body:json {
  {"topic":"Speed, Distance, and Time for Grade 6","description":"A short quiz about the relationship between speed, distance, and time.","type":"QUIZ","difficulty":"EASY","questionCount":3,"maxScore":10}
}

tests {
  const j = (() => { try { return res.getBody(); } catch (e) { return null; } })();
  const noPlaceholder = (blob) => { const s = (blob || '').toLowerCase(); expect(s, 'must not contain placeholder/template text').to.not.include('an accurate statement about'); expect(s).to.not.include('a common misconception about'); expect(s).to.not.include('a statement unrelated to'); };
  const aiConfigured = bru.getVar('aiConfigured') === 'true';
  if (res.getStatus() === 200) {
    test('has id', () => expect(j).to.have.property('id'));
    test('status is PENDING_REVIEW (auto-submitted to review)', () => expect(j.status).to.eql('PENDING_REVIEW'));
    test('has nested questions', () => expect(j.questions).to.be.an('array').that.is.not.empty);
    test('NO placeholder/template content (real AI output)', () => noPlaceholder(JSON.stringify(j)));
    test('description is clean plain text', () => { expect(j.description).to.be.a('string'); expect(j.description).to.not.include('\n'); expect(j.description).to.not.include('**'); expect(j.description).to.not.include('Here is'); });
    test('english response omits fieldLabels', () => expect(j).to.not.have.property('fieldLabels'));
    if (j && j.id) bru.setVar('activityId', j.id);
    if (j.questions && j.questions.length) { const q = j.questions[0]; bru.setVar('questionId', q.id); const opts = q.options || []; const correct = opts.find(o => o.isCorrect) || opts[0]; if (correct) bru.setVar('optionId', correct.id); }
  } else {
    test('AI unavailable -> clear failure, NOT fallback content', () => { expect(res.getStatus()).to.eql(400); expect((j && j.message ? j.message : '').toLowerCase()).to.match(/not configured|openai_api_key|ai provider|generation failed|invalid json|placeholder/); });
    test('error body has NO placeholder/template content', () => noPlaceholder(JSON.stringify(j)));
    if (aiConfigured) { test('configured AI must generate (check model/account)', () => { throw new Error('AI health=READY but generate returned ' + res.getStatus() + '; verify the configured model is valid for the account.'); }); }
    else { console.log('Generate correctly failed: no OPENAI_API_KEY. Set it to generate and run folders 03-08.'); }
  }
}
