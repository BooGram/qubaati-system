meta {
  name: ab - Teacher Cannot Call Parent AI Insight (403)
  type: http
  seq: 16
}

post {
  url: {{baseUrl}}/ai/parents/me/dashboard-insight
  body: none
  auth: basic
}

auth:basic {
  username: {{teacherUsername}}
  password: {{teacherPassword}}
}

tests {
  test('teacher on parent AI insight -> 403', () => expect(res.getStatus()).to.eql(403));
}
