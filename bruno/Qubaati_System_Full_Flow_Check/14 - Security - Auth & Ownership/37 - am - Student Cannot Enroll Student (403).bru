meta {
  name: am - Student Cannot Enroll Student (403)
  type: http
  seq: 37
}

post {
  url: {{baseUrl}}/classrooms/students/enroll
  body: json
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

headers {
  Content-Type: application/json
}

body:json {
  {"classroomId":{{classroomId}},"studentId":{{studentId}}}
}

tests {
  test('expected 403', () => expect(res.getStatus()).to.eql(403));
}
