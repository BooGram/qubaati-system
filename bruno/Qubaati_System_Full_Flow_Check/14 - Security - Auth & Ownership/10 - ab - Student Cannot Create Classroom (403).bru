meta {
  name: ab - Student Cannot Create Classroom (403)
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/classrooms/add
  body: json
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

headers {
  Content-Type: application/json
}

body:json {
  {"name":"Blocked Classroom","gradeLevel":6,"section":"A"}
}

tests {
  test('student creating a classroom -> 403', () => expect(res.getStatus()).to.eql(403));
}
