meta {
  name: am - Get Student Activity Results
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/students/me/activity-results
  body: none
  auth: basic
}

auth:basic {
  username: {{studentUsername}}
  password: {{studentPassword}}
}

tests {
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  test('is an array', () => expect(res.getBody()).to.be.an('array'));
}
