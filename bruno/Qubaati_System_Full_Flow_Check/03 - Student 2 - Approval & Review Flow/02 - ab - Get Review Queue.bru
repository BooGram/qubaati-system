meta {
  name: ab - Get Review Queue
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/activities/review-queue
  body: none
  auth: basic
}

auth:basic {
  username: {{teacherUsername}}
  password: {{teacherPassword}}
}

tests {
  const json = res.getBody();
  test('status 200', () => expect(res.getStatus()).to.equal(200));
  const id = bru.getVar('activityId');
  test('review queue contains the activity', () => expect(json.some(a => String(a.id) === String(id))).to.be.true);
}
